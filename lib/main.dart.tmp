                  const SizedBox(height: 6),
                  Text('${alunos.length} aluno(s) • ${aulasLancadas.length}/$totalAulas aula(s) lançada(s) • ${turma.status}'),
                  const SizedBox(height: 14),
                  Wrap(
                    spacing: 8,
                    runSpacing: 8,
